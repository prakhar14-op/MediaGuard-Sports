# ─── LLM APIs (at least one required) ────────────────────────────────────────
GROQ_API_KEY=gsk_...          # Groq API key — llama-3.1-8b-instant + llama-3.3-70b
GEMINI_API_KEY=AIza...         # Google Gemini fallback — gemini-2.0-flash-lite

# ─── Services ─────────────────────────────────────────────────────────────────
FASTAPI_URL=http://127.0.0.1:8001   # FastAPI ML service URL
MONGO_URI=mongodb://127.0.0.1:27017/mediaguard
REDIS_URL=redis://127.0.0.1:6379   # or rediss:// for Upstash TLS

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development
CLIENT_URL=http://localhost:5173    # Frontend URL (for CORS)

# ─── YouTube (optional — helps bypass bot detection on cloud IPs) ─────────────
# Export cookies from a logged-in YouTube session, then:
# base64 -w 0 cookies.txt | pbcopy
YOUTUBE_COOKIES_B64=

# ─── Forensics Model (optional — switches from heuristic to neural mode) ──────
# After training with train_forensics.py:
#   gsutil cp checkpoints/best.pth gs://YOUR_BUCKET/forensics/best.pth
# Then set:
FORENSICS_MODEL_PATH=             # Local path to best.pth (e.g. /tmp/forensics.pth)
FORENSICS_MODEL_GCS=              # GCS path (e.g. gs://my-bucket/forensics/best.pth)

# ─── Training (only needed when running train_forensics.py) ───────────────────
GCS_BUCKET=                       # GCS bucket name for auto-uploading best.pth
                                  # e.g. my-mediaguard-bucket (without gs://)

# ─── Render keepalive (only on Render free tier) ──────────────────────────────
RENDER_EXTERNAL_URL=https://mediaguard-node.onrender.com

# ─── Proxy (optional — helps bypass YouTube bot detection) ───────────────────
PROXY_URL=                        # e.g. http://proxy.example.com:8080
